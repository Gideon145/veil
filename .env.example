# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Your deployer wallet private key (no 0x prefix)
PRIVATE_KEY=your_private_key_here

# Optional: Arbiscan API key for contract verification
ARBISCAN_API_KEY=

# ── Agent env vars (agent/.env or Railway variables) ──────────────────────────
VEIL_PRIVATE_KEY=your_private_key_here
ARB_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CDS_ADDRESS=0xB2326A7A1EA88054906b16783B12E451d1Af0791
INTERVAL_MS=30000
STATUS_PORT=3001
